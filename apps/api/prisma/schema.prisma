// =====================================================
// RHM Play - Prisma schema
// =====================================================
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Enums ----------

enum UserRole {
  STUDENT
  INSTRUCTOR
  ADMIN
}

// ---------- Models ----------

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  fullName  String
  role      UserRole @default(STUDENT)
  createdAt DateTime @default(now())

  @@index([email])
  @@map("users")
}

model Series {
  id          String   @id @default(cuid())
  title       String
  description String?
  thumbnail   String?
  createdAt   DateTime @default(now())

  episodes Episode[]

  @@map("series")
}

model Episode {
  id          String   @id @default(cuid())
  title       String
  description String?
  videoUrl    String
  order       Int
  isFree      Boolean  @default(false)
  createdAt   DateTime @default(now())

  seriesId String
  series   Series @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  @@unique([seriesId, order])
  @@index([seriesId])
  @@map("episodes")
}
