# Copy to .env and fill in real values.
#
# Use the Neon DIRECT (non-pooled) endpoint here — Prisma migrations need
# a direct connection. The host looks like:
#     ep-<id>.<region>.aws.neon.tech         ← direct (use this)
#     ep-<id>-pooler.<region>.aws.neon.tech  ← pooled (blocks migrate)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxxx.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

NODE_ENV=development
PORT=4000

# Comma-separated list of allowed CORS origins for production.
# Leave unset in dev — main.ts then echoes the request origin.
# ALLOWED_ORIGINS=https://rhm-play.vercel.app,https://www.rhmplay.com

JWT_SECRET=replace-me-with-a-long-random-string
JWT_EXPIRES_IN=7d
